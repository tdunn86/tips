<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.csce247.QuestionDetailController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #f2f2f2; -fx-background: #f2f2f2; -fx-border-color: transparent;">

    <content>
        <VBox spacing="18.0" style="-fx-background-color: #f2f2f2;">
            <padding>
                <Insets top="24" right="24" bottom="60" left="24"/>
            </padding>

            <Button text="← Back to Questions"
                    onAction="#handleBackToQuestions"
                    style="-fx-background-color: transparent; -fx-text-fill: #555555; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 6 0 6 0; -fx-background-insets: 0; -fx-border-color: transparent;" />

            <HBox spacing="20" alignment="TOP_LEFT">

                <VBox spacing="16" HBox.hgrow="ALWAYS">

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                 -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                        <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                        <Label fx:id="lblTitle"
                               text="Question Title"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblDifficulty"
                                   text="Easy"
                                   style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-background-radius: 999; -fx-padding: 3 10 3 10;"/>
                            <Label fx:id="lblLanguage"
                                   text="Java"
                                   style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
                            <Label text="•" style="-fx-text-fill: #bbbbbb;"/>
                            <Label fx:id="lblCourse"
                                   text="CSCE 146"
                                   style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
                        </HBox>

                        <Separator />

                        <Label text="Problem Description"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                        <Label fx:id="lblPrompt"
                               text=""
                               wrapText="true"
                               style="-fx-font-size: 13px; -fx-text-fill: #333333; -fx-line-spacing: 4;"/>
                    </VBox>

                    <VBox fx:id="hintBox"
                          spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                 -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>

                        <Button fx:id="btnToggleHint"
                                text="Show Hint"
                                onAction="#handleToggleHint"
                                style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #333333; -fx-cursor: hand; -fx-padding: 0; -fx-background-insets: 0; -fx-border-color: transparent;" />

                        <Label fx:id="lblHint"
                               text=""
                               wrapText="true"
                               visible="false"
                               managed="false"
                               style="-fx-font-size: 13px; -fx-text-fill: #444444; -fx-padding: 0 0 0 0;"/>
                    </VBox>

                </VBox>

                <VBox spacing="16" prefWidth="320">

                    <VBox fx:id="solutionBox"
                          spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                 -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                        <Button fx:id="btnViewSolution"
                                text="View Solution"
                                onAction="#handleViewSolution"
                                style="-fx-background-color: #8b1a1a; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 12 16 12 16; -fx-font-size: 13px; -fx-font-weight: bold;" />

                        <Label fx:id="lblSampleSolution"
                               text=""
                               wrapText="true"
                               visible="false"
                               managed="false"
                               style="-fx-font-size: 12px; -fx-text-fill: #333333; -fx-font-family: monospace; -fx-background-color: #f6f6f6; -fx-background-radius: 6; -fx-padding: 10;"/>

                        <Label fx:id="lblSampleExplanation"
                               text=""
                               wrapText="true"
                               visible="false"
                               managed="false"
                               style="-fx-font-size: 12px; -fx-text-fill: #555555; -fx-padding: 4 0 0 0;"/>
                    </VBox>

                    <VBox spacing="10"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                 -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                        <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
                        <Label text="Discussion"
                               style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #333333;"/>
                        <Label text="Discussion can go here later."
                               style="-fx-font-size: 12px; -fx-text-fill: #666666;"/>
                    </VBox>

                </VBox>
            </HBox>
        </VBox>
    </content>
</ScrollPane>