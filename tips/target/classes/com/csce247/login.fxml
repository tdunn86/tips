<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml"
           prefWidth="600" prefHeight="400"
           style="-fx-background-color: #f2f2f2;">

    <!-- Card Container -->
    <VBox spacing="12"
          alignment="CENTER"
          maxWidth="300"
          style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10,0,0,4);">

        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Icon -->
        <StackPane prefWidth="50" prefHeight="50"
                   style="-fx-background-color: #8B0000; -fx-background-radius: 10;">
            <Label text="&lt;/&gt;" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
        </StackPane>

        <!-- Title -->
        <Label text="Welcome to TIPS"
               style="-fx-font-size: 18; -fx-font-weight: bold;"/>

        <!-- Subtitle -->
        <Label text="Technical Interview Preparation System"
               style="-fx-text-fill: gray; -fx-font-size: 11;"/>

        <!-- Username -->
        <VBox alignment="TOP_LEFT" spacing="4">
            <Label text="Username"/>
            <TextField promptText="Enter your username"
                       prefHeight="30"/>
        </VBox>

        <!-- Password -->
        <VBox alignment="TOP_LEFT" spacing="4">
            <Label text="Password"/>
            <PasswordField promptText="Enter your password"
                           prefHeight="30"/>
        </VBox>

        <!-- Login Button -->
        <Button text="Login"
                maxWidth="Infinity"
                prefHeight="35"
                style="-fx-background-color: #8B0000; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <!-- Create Account -->
        <Hyperlink text="Create Account"
                   style="-fx-text-fill: #8B0000;"/>

    </VBox>

</StackPane>