<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #f6f6f6; -fx-background: #f6f6f6;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.csce247.DailyChallengeController">

    <content>
        <VBox spacing="18.0" style="-fx-background-color: #f6f6f6;">
            <padding>
                <Insets top="24" right="24" bottom="60" left="24"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="8.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e0e0e0;">
                <padding>
                    <Insets top="28" right="28" bottom="28" left="28"/>
                </padding>

                <Label fx:id="challengeDateLabel"
                       style="-fx-font-size: 12px; -fx-text-fill: #8b5e0a; -fx-font-weight: bold;" />

                <Label fx:id="challengeTitleLabel"
                       style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #73000a;" />

                <Label text="A new problem appears each day based on your level."
                       style="-fx-font-size: 14px; -fx-text-fill: #555555;" />

                <VBox spacing="10">
                    <Label fx:id="difficultyLabel"/>
                    <Label fx:id="courseLabel"/>
                    <Label fx:id="languageLabel"/>
                </VBox>

            </VBox>

            <!-- PROMPT -->
            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e0e0e0;">
                <padding>
                    <Insets top="22" right="22" bottom="22" left="22"/>
                </padding>

                <Label text="Problem Prompt"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <TextArea fx:id="challengePromptArea"
                          editable="false"
                          wrapText="true"
                          prefRowCount="12"
                          style="-fx-background-color: white; -fx-font-size: 13px;" />
            </VBox>

            <!-- SOLUTION -->
            <VBox fx:id="solutionBox"
                  spacing="10"
                  style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #e0e0e0;">
                <padding>
                    <Insets top="16" right="16" bottom="16" left="16"/>
                </padding>

                <Button fx:id="btnViewSolution"
                        text="View Solution"
                        onAction="#handleViewSolution"
                        style="-fx-background-color: #8b1a1a; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 12 16; -fx-font-size: 13px; -fx-font-weight: bold;" />

                <Label fx:id="lblSampleSolution"
                       visible="false"
                       managed="false"
                       wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #333333; -fx-font-family: monospace; -fx-background-color: #f6f6f6; -fx-background-radius: 6; -fx-padding: 10;" />

                <Label fx:id="lblSampleExplanation"
                       visible="false"
                       managed="false"
                       wrapText="true"
                       style="-fx-font-size: 12px; -fx-text-fill: #555555;" />
            </VBox>

        </VBox>
    </content>
</ScrollPane>