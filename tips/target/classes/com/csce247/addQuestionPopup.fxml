<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.csce247.AddQuestionPopupController"
      spacing="18"
      prefWidth="640"
      prefHeight="560"
      style="-fx-background-color: #f8f8f8;">

    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <VBox spacing="6"
          style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e6e6e6; -fx-border-radius: 18; -fx-padding: 24;">
        
        <Label fx:id="lblTitle"
               text="Create New Question"
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111111;" />

        <Label fx:id="lblSubtitle"
               text="Add a new coding problem for students to practice."
               style="-fx-font-size: 13px; -fx-text-fill: #666666;" />

        <Label fx:id="lblError"
               text="Error goes here"
               visible="false"
               managed="false"
               wrapText="true"
               style="-fx-text-fill: #b42318; -fx-background-color: #fef3f2; -fx-border-color: #fecdca; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12 10 12;" />
    </VBox>

    <VBox spacing="16"
          style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e6e6e6; -fx-border-radius: 18; -fx-padding: 24;">

        <VBox spacing="8">
            <Label text="Question Title"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #222222;" />
            <TextField fx:id="tfQuestionTitle"
                       promptText="e.g. Longest Subarray with Sum K"
                       style="-fx-background-color: #fafafa; -fx-border-color: #d9d9d9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12 10 12; -fx-font-size: 13px;" />
        </VBox>

        <VBox spacing="8">
            <Label text="Prompt"
                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #222222;" />
            <TextArea fx:id="taPrompt"
                      promptText="Write the full problem statement here..."
                      prefRowCount="10"
                      wrapText="true"
                      style="-fx-background-color: #fafafa; -fx-border-color: #d9d9d9; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10 12 10 12; -fx-font-size: 13px;" />
        </VBox>

        <HBox spacing="14">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Difficulty"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #222222;" />
                <ComboBox fx:id="cbDifficulty"
                          prefWidth="180"
                          style="-fx-background-color: #fafafa; -fx-font-size: 13px;" />
            </VBox>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Language"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #222222;" />
                <ComboBox fx:id="cbLanguage"
                          prefWidth="180"
                          style="-fx-background-color: #fafafa; -fx-font-size: 13px;" />
            </VBox>

            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="Course"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #222222;" />
                <ComboBox fx:id="cbCourse"
                          prefWidth="180"
                          style="-fx-background-color: #fafafa; -fx-font-size: 13px;" />
            </VBox>
        </HBox>
    </VBox>

    <HBox spacing="12"
          style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: #e6e6e6; -fx-border-radius: 18; -fx-padding: 18 24 18 24;">
        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="btnCancel"
                text="Cancel"
                onAction="#handleCancel"
                style="-fx-background-color: #f2f4f7; -fx-text-fill: #344054; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 18 10 18; -fx-cursor: hand;" />

        <Button fx:id="btnCreate"
                text="Create Question"
                onAction="#handleCreateQuestion"
                style="-fx-background-color: #8a0011; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 18 10 18; -fx-cursor: hand;" />
    </HBox>
</VBox>