<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.csce247.MainController"
           style="-fx-background-color: #f6f6f6;">

    <BorderPane style="-fx-background-color: #f6f6f6;">

        <top>
            <HBox alignment="CENTER_LEFT"
                  spacing="14.0"
                  style="-fx-background-color: white; -fx-border-color: transparent transparent #dfdfdf transparent; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 8, 0.15, 0, 2);">
                <padding>
                    <Insets top="20.0" right="32.0" bottom="20.0" left="32.0"/>
                </padding>

                <Button fx:id="logoButton"
                        mnemonicParsing="false"
                        onAction="#goDashboard"
                        text="&lt;/&gt;"
                        style="-fx-background-color: #8a0011; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: 700; -fx-background-radius: 14; -fx-min-width: 58; -fx-min-height: 58; -fx-pref-width: 58; -fx-pref-height: 58; -fx-padding: 0;" />

                <Label text="TIPS"
                       style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #111111;" />

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="10.0">

                    <Button fx:id="homeNavButton"
                            mnemonicParsing="false"
                            onAction="#goDashboard"
                            style="-fx-background-color: transparent; -fx-background-radius: 14; -fx-padding: 12 18 12 18; -fx-min-height: 46; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <Label fx:id="homeIconLabel"
                                       text="⌂"
                                       style="-fx-font-size: 18px; -fx-min-width: 20; -fx-min-height: 20; -fx-text-fill: #111111;" />
                                <Label fx:id="homeTextLabel"
                                       text="Home"
                                       style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #111111;" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button fx:id="questionsNavButton"
                            mnemonicParsing="false"
                            onAction="#goQuestions"
                            style="-fx-background-color: transparent; -fx-background-radius: 14; -fx-padding: 12 18 12 18; -fx-min-height: 46; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <Label fx:id="questionsIconLabel"
                                       text="☷"
                                       style="-fx-font-size: 18px; -fx-min-width: 20; -fx-min-height: 20; -fx-text-fill: #111111;" />
                                <Label fx:id="questionsTextLabel"
                                       text="Questions"
                                       style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #111111;" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button fx:id="dailyChallengeNavButton"
                            mnemonicParsing="false"
                            onAction="#goDailyChallenge"
                            style="-fx-background-color: transparent; -fx-background-radius: 14; -fx-padding: 12 18 12 18; -fx-min-height: 46; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <Label fx:id="dailyChallengeIconLabel"
                                       text="🏆"
                                       style="-fx-font-size: 18px; -fx-min-width: 20; -fx-min-height: 20; -fx-text-fill: #111111;" />
                                <Label fx:id="dailyChallengeTextLabel"
                                       text="Daily Challenge"
                                       style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #111111;" />
                            </HBox>
                        </graphic>
                    </Button>

                    <Button fx:id="contributorNavButton"
                            mnemonicParsing="false"
                            onAction="#goContributor"
                            style="-fx-background-color: transparent; -fx-background-radius: 14; -fx-padding: 12 18 12 18; -fx-min-height: 46; -fx-alignment: CENTER_LEFT; -fx-cursor: hand;">
                        <graphic>
                            <HBox alignment="CENTER" spacing="8.0">
                                <Label fx:id="contributorIconLabel"
                                       text="✎"
                                       style="-fx-font-size: 18px; -fx-min-width: 20; -fx-min-height: 20; -fx-text-fill: #111111;" />
                                <Label fx:id="contributorTextLabel"
                                       text="Contributor"
                                       style="-fx-font-size: 16px; -fx-font-weight: 600; -fx-text-fill: #111111;" />
                            </HBox>
                        </graphic>
                    </Button>
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <Label fx:id="usernameLabel"
                       text="Username"
                       style="-fx-font-size: 18px; -fx-text-fill: #6a6a6a;" />

                <Button fx:id="profileButton"
                        mnemonicParsing="false"
                        onAction="#toggleProfilePopup"
                        text="U"
                        style="-fx-background-color: #8a0011; -fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: 700; -fx-background-radius: 999; -fx-min-width: 46; -fx-min-height: 46; -fx-pref-width: 46; -fx-pref-height: 46; -fx-padding: 0;" />
            </HBox>
        </top>

        <center>
            <StackPane fx:id="contentArea" />
        </center>
    </BorderPane>

    <StackPane fx:id="profileOverlay"
               visible="false"
               managed="false"
               onMouseClicked="#closeProfilePopup"
               pickOnBounds="true">

        <VBox maxWidth="320.0"
              StackPane.alignment="TOP_RIGHT"
              onMouseClicked="#consumeProfilePopupClick"
              style="-fx-background-color: white; -fx-background-radius: 18; -fx-border-color: rgba(0,0,0,0.12); -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 20, 0.18, 0, 6);">
            <StackPane.margin>
                <Insets top="88.0" right="22.0" bottom="0.0" left="0.0"/>
            </StackPane.margin>
            <padding>
                <Insets top="22.0" right="22.0" bottom="22.0" left="22.0"/>
            </padding>

            <children>
                <VBox fx:id="profilePopup" spacing="16.0">
                    <Label text="Profile"
                           style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #111111;" />

                    <VBox spacing="12.0"
                          style="-fx-background-color: #fafafa; -fx-background-radius: 14; -fx-border-color: #ececec; -fx-border-radius: 14;">
                        <padding>
                            <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
                        </padding>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Account Type"
                                   style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #555555; -fx-min-width: 110;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="accountTypeValueLabel"
                                   text="STUDENT"
                                   style="-fx-font-size: 15px; -fx-text-fill: #111111;" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Username"
                                   style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #555555; -fx-min-width: 110;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="usernameValueLabel"
                                   text="username"
                                   style="-fx-font-size: 15px; -fx-text-fill: #111111;" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Email"
                                   style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #555555; -fx-min-width: 110;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="emailValueLabel"
                                   text="user@email.com"
                                   wrapText="true"
                                   style="-fx-font-size: 15px; -fx-text-fill: #111111;" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="User ID"
                                   style="-fx-font-size: 15px; -fx-font-weight: 700; -fx-text-fill: #555555; -fx-min-width: 110;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="userIdValueLabel"
                                   text="0"
                                   style="-fx-font-size: 15px; -fx-text-fill: #111111;" />
                        </HBox>
                    </VBox>

                    <Button text="Log Out"
                            onAction="#handleLogout"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-min-height: 48; -fx-background-color: #8a0011; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 17px; -fx-font-weight: 700;" />
                </VBox>
            </children>
        </VBox>
    </StackPane>

</StackPane>