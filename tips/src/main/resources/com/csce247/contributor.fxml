<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1365.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.csce247.ContributorController"
            style="-fx-background-color: #f6f6f6;">

    <!-- ============================================================== -->
    <!-- TOP NAV BAR                                                      -->
    <!-- ============================================================== -->
    <top>
        <VBox>
            <children>
                <HBox prefHeight="58.0" alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: white;
                             -fx-border-color: #dddddd;
                             -fx-border-width: 0 0 1 0;">
                    <padding><Insets top="0" right="18" bottom="0" left="18"/></padding>
                    <children>

                        <!-- Logo -->
                        <HBox alignment="CENTER" spacing="10">
                            <children>
                                <StackPane prefWidth="34" prefHeight="34"
                                           style="-fx-background-color: #8b1115; -fx-background-radius: 8;">
                                    <children>
                                        <Label text="&lt;/&gt;"
                                               style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                                    </children>
                                </StackPane>
                                <Label text="TIPS"
                                       style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Navigation links -->
                        <HBox alignment="CENTER" spacing="20">
                            <children>
                                <Label text="⌂  Home"
                                       style="-fx-font-size: 13; -fx-text-fill: #222222; -fx-cursor: hand;"
                                       onMouseClicked="#handleNavHome"/>
                                <Label text="≡  Questions"
                                       style="-fx-font-size: 13; -fx-text-fill: #222222; -fx-cursor: hand;"
                                       onMouseClicked="#handleNavQuestions"/>
                                <Label text="⌛  Daily Challenge"
                                       style="-fx-font-size: 13; -fx-text-fill: #222222; -fx-cursor: hand;"
                                       onMouseClicked="#handleNavDailyChallenge"/>

                                <!-- Active page badge (no nav needed — already here) -->
                                <StackPane style="-fx-background-color: #8b1115; -fx-background-radius: 6;">
                                    <padding><Insets top="8" right="14" bottom="8" left="14"/></padding>
                                    <children>
                                        <Label text="Contributor"
                                               style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS"/>

                        <!-- Username + avatar / logout -->
                        <HBox alignment="CENTER" spacing="12">
                            <children>
                                <Label fx:id="lblUsername"
                                       text="..."
                                       style="-fx-font-size: 14; -fx-text-fill: #888888;"/>
                                <StackPane prefWidth="32" prefHeight="32"
                                           style="-fx-background-color: #8b1115;
                                                  -fx-background-radius: 16;
                                                  -fx-cursor: hand;"
                                           onMouseClicked="#handleNavLogout">
                                    <children>
                                        <Label text="☺"
                                               style="-fx-text-fill: white; -fx-font-size: 14;"/>
                                    </children>
                                </StackPane>
                            </children>
                        </HBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <!-- ============================================================== -->
    <!-- MAIN CONTENT                                                     -->
    <!-- ============================================================== -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #f6f6f6; -fx-background: #f6f6f6;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <content>
                <AnchorPane style="-fx-background-color: #f6f6f6;">
                    <children>
                        <VBox layoutX="18.0" layoutY="18.0" spacing="18" prefWidth="1328.0">
                            <children>

                                <!-- ==================================== -->
                                
                                <!-- Page title + Add Question button      -->
                                <!-- ==================================== -->
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Contributor Dashboard"
                                                       style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                                                <Label text="Track your contributions and approval status"
                                                       style="-fx-font-size: 14; -fx-text-fill: #808080;"/>
                                            </children>
                                        </VBox>

                                        <StackPane fx:id="btnAddQuestion"
                                                   style="-fx-background-color: #8b1115;
                                                          -fx-background-radius: 8;
                                                          -fx-cursor: hand;"
                                                   onMouseClicked="#handleAddQuestion">
                                            <padding><Insets top="10" right="18" bottom="10" left="18"/></padding>
                                            <children>
                                                <Label text="＋ Add Question"
                                                       style="-fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;"/>
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>

                                <!-- ==================================== -->
                                <!-- Stat cards                            -->
                                <!-- ==================================== -->
                                <HBox spacing="18">
                                    <children>

                                        <!-- Problems Submitted -->
                                        <VBox prefWidth="420" prefHeight="78" spacing="2"
                                              style="-fx-background-color: white;
                                                     -fx-background-radius: 10;
                                                     -fx-border-color: #e4e4e4;
                                                     -fx-border-radius: 10;">
                                            <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                            <children>
                                                <HBox spacing="12" alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane prefWidth="38" prefHeight="38"
                                                                   style="-fx-background-color: #d8e8ff; -fx-background-radius: 8;">
                                                            <children>
                                                                <Label text="📄"
                                                                       style="-fx-font-size: 17; -fx-text-fill: #2874ff;"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="2">
                                                            <children>
                                                                <Label text="Problems Submitted"
                                                                       style="-fx-font-size: 12; -fx-text-fill: #7a7a7a;"/>
                                                                <Label fx:id="lblProblemsSubmitted"
                                                                       text="0"
                                                                       style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Solutions Written -->
                                        <VBox prefWidth="420" prefHeight="78" spacing="2"
                                              style="-fx-background-color: white;
                                                     -fx-background-radius: 10;
                                                     -fx-border-color: #e4e4e4;
                                                     -fx-border-radius: 10;">
                                            <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                            <children>
                                                <HBox spacing="12" alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane prefWidth="38" prefHeight="38"
                                                                   style="-fx-background-color: #eddcff; -fx-background-radius: 8;">
                                                            <children>
                                                                <Label text="✏"
                                                                       style="-fx-font-size: 17; -fx-text-fill: #8b44cc;"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="2">
                                                            <children>
                                                                <Label text="Solutions Written"
                                                                       style="-fx-font-size: 12; -fx-text-fill: #7a7a7a;"/>
                                                                <Label fx:id="lblSolutionsWritten"
                                                                       text="0"
                                                                       style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                        <!-- Approval Rate -->
                                        <VBox prefWidth="420" prefHeight="78" spacing="2"
                                              style="-fx-background-color: white;
                                                     -fx-background-radius: 10;
                                                     -fx-border-color: #e4e4e4;
                                                     -fx-border-radius: 10;">
                                            <padding><Insets top="16" right="18" bottom="16" left="18"/></padding>
                                            <children>
                                                <HBox spacing="12" alignment="CENTER_LEFT">
                                                    <children>
                                                        <StackPane prefWidth="38" prefHeight="38"
                                                                   style="-fx-background-color: #def7e6; -fx-background-radius: 8;">
                                                            <children>
                                                                <Label text="↗"
                                                                       style="-fx-font-size: 18; -fx-text-fill: #20a94f; -fx-font-weight: bold;"/>
                                                            </children>
                                                        </StackPane>
                                                        <VBox spacing="2">
                                                            <children>
                                                                <Label text="Approval Rate"
                                                                       style="-fx-font-size: 12; -fx-text-fill: #7a7a7a;"/>
                                                                <Label fx:id="lblApprovalRate"
                                                                       text="0%"
                                                                       style="-fx-font-size: 20; -fx-font-weight: bold;"/>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                                <!-- ==================================== -->
                                <!-- Tab bar                               -->
                                <!-- ==================================== -->
                                <StackPane prefHeight="38"
                                           style="-fx-background-color: #dddddd; -fx-background-radius: 12;">
                                    <children>
                                        <HBox spacing="0" alignment="CENTER_LEFT">
                                            <children>

                                                <StackPane fx:id="tabApproved"
                                                           prefWidth="440" prefHeight="38"
                                                           style="-fx-background-color: white;
                                                                  -fx-background-radius: 12;
                                                                  -fx-border-color: #d0d0d0;
                                                                  -fx-border-radius: 12;
                                                                  -fx-border-width: 1;
                                                                  -fx-cursor: hand;"
                                                           onMouseClicked="#onTabApproved">
                                                    <children>
                                                        <Label fx:id="lblTabApproved"
                                                               text="◔  Approved (0)"
                                                               style="-fx-font-size: 14; -fx-text-fill: #222222;"/>
                                                    </children>
                                                </StackPane>

                                                <StackPane fx:id="tabPending"
                                                           prefWidth="440" prefHeight="38"
                                                           style="-fx-background-color: transparent; -fx-cursor: hand;"
                                                           onMouseClicked="#onTabPending">
                                                    <children>
                                                        <Label fx:id="lblTabPending"
                                                               text="◔  Pending Review (0)"
                                                               style="-fx-font-size: 14; -fx-text-fill: #222222;"/>
                                                    </children>
                                                </StackPane>

                                                <StackPane fx:id="tabRejected"
                                                           prefWidth="440" prefHeight="38"
                                                           style="-fx-background-color: transparent; -fx-cursor: hand;"
                                                           onMouseClicked="#onTabRejected">
                                                    <children>
                                                        <Label fx:id="lblTabRejected"
                                                               text="⊗  Rejected (0)"
                                                               style="-fx-font-size: 14; -fx-text-fill: #222222;"/>
                                                    </children>
                                                </StackPane>

                                            </children>
                                        </HBox>
                                    </children>
                                </StackPane>

                                <!-- ==================================== -->
                                <!-- Question list (built by controller)   -->
                                <!-- ==================================== -->
                                <VBox fx:id="questionListVBox" spacing="12">
                                    <!-- ContributorController.renderTab() populates this -->
                                </VBox>

                                <!-- Bottom breathing room -->
                                <Region prefHeight="24"/>

                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </content>
        </ScrollPane>
    </center>

</BorderPane>
