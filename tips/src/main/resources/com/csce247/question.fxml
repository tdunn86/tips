<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.csce247.QuestionsController"
            prefWidth="1080" prefHeight="800"
            style="-fx-background-color: #f2f2f2;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="4"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;"
              prefHeight="56">
            <padding><Insets top="0" right="32" bottom="0" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&lt;/&gt;"
                       style="-fx-background-color: #8b1a1a; -fx-text-fill: white;
                              -fx-font-weight: bold; -fx-font-size: 13px;
                              -fx-background-radius: 6; -fx-padding: 6 8 6 8;"/>
                <Label text="TIPS" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
            </HBox>

            <HBox spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <padding><Insets left="24"/></padding>
                <Button text="Home" fx:id="btnHome" onAction="#handleHome"
                        style="-fx-background-color: transparent; -fx-text-fill: #555555;
                               -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 6 14 6 14;
                               -fx-cursor: hand;"/>
                <Button text="Questions" fx:id="btnQuestions"
                        style="-fx-background-color: #8b1a1a; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 6 14 6 14;
                               -fx-cursor: hand;"/>
                <Button text="Daily Challenge" fx:id="btnDailyChallenge" onAction="#handleDailyChallenge"
                        style="-fx-background-color: transparent; -fx-text-fill: #555555;
                               -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 6 14 6 14;
                               -fx-cursor: hand;"/>
                <Button text="Contributor" fx:id="btnContributor" onAction="#handleContributor"
                        style="-fx-background-color: transparent; -fx-text-fill: #555555;
                               -fx-font-size: 13px; -fx-background-radius: 8; -fx-padding: 6 14 6 14;
                               -fx-cursor: hand;"/>
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <Label text="JohnGamecock" style="-fx-font-size: 13px; -fx-font-weight: 500;"/>
                <Label text="👤"
                       style="-fx-background-color: #8b1a1a; -fx-text-fill: white;
                              -fx-background-radius: 50; -fx-padding: 6 8 6 8;"/>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #f2f2f2; -fx-background-color: #f2f2f2;
                           -fx-border-color: transparent;">
            <VBox spacing="0">
                <padding><Insets top="36" right="24" bottom="60" left="24"/></padding>

                <Label text="Questions"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;">
                    <VBox.margin><Insets bottom="24"/></VBox.margin>
                </Label>

                <VBox style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                             -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                    <VBox.margin><Insets bottom="32"/></VBox.margin>

                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <HBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-border-color: #e0e0e0; -fx-border-width: 1.5;
                                     -fx-background-color: white; -fx-background-radius: 7;
                                     -fx-border-radius: 7; -fx-padding: 8 14 8 14;"
                              HBox.hgrow="ALWAYS">
                            <Label text="🔍" style="-fx-text-fill: #888888;"/>
                            <TextField fx:id="searchField" promptText="Search questions..."
                                       style="-fx-background-color: transparent;
                                              -fx-border-color: transparent; -fx-font-size: 13px;"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                        <ComboBox fx:id="difficultyFilter" prefWidth="160"
                                  style="-fx-font-size: 13px;"/>
                        <ComboBox fx:id="languageFilter" prefWidth="160"
                                  style="-fx-font-size: 13px;"/>
                    </HBox>

                    <HBox spacing="14">
                        <VBox.margin><Insets top="14"/></VBox.margin>
                        <ComboBox fx:id="courseFilter" prefWidth="180"
                                  style="-fx-font-size: 13px;"/>
                    </HBox>
                </VBox>

                <VBox fx:id="questionList" spacing="14"/>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>