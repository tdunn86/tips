<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.csce247.DashboardController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">

    <content>
        <VBox spacing="34.0"
              style="-fx-background-color: transparent;">
            <padding>
                <Insets top="24.0" right="32.0" bottom="40.0" left="32.0"/>
            </padding>

            <VBox spacing="10.0">
                <Label fx:id="greetingLabel"
                       text="Hello, User! 👋"
                       style="-fx-font-size: 56px; -fx-font-weight: 800; -fx-text-fill: #111111;" />
                <Label fx:id="subtitleLabel"
                       text="Ready to sharpen your coding skills today?"
                       wrapText="true"
                       style="-fx-font-size: 22px; -fx-text-fill: #707070;" />
            </VBox>

            <HBox alignment="CENTER_LEFT"
                  spacing="18.0"
                  style="-fx-background-color: linear-gradient(to right, rgba(138, 0, 17, 0.09), rgba(138, 0, 17, 0.05)); -fx-border-color: rgba(138, 0, 17, 0.24); -fx-border-width: 1; -fx-border-radius: 16; -fx-background-radius: 16; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.15, 0, 2); -fx-min-height: 110; -fx-alignment: CENTER_LEFT;">
                <padding>
                    <Insets top="26.0" right="28.0" bottom="26.0" left="28.0"/>
                </padding>

                <StackPane style="-fx-background-color: #8a0011; -fx-background-radius: 999; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                    <Label text="🔥"
                           style="-fx-font-size: 32px;" />
                </StackPane>

                <VBox spacing="4.0">
                    <Label fx:id="streakValueLabel"
                           text="0 Days"
                           style="-fx-font-size: 38px; -fx-font-weight: 800; -fx-text-fill: #111111;" />
                    <Label fx:id="streakLabel"
                           text="Current Streak - Keep it up!"
                           wrapText="true"
                           style="-fx-font-size: 18px; -fx-text-fill: #6e6e6e;" />
                </VBox>
            </HBox>

            <GridPane hgap="26.0" vgap="26.0">
                <columnConstraints>
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3333" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3333" />
                    <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3333" />
                </columnConstraints>

                <VBox GridPane.columnIndex="0"
                      spacing="18.0"
                      style="-fx-background-color: white; -fx-border-color: rgba(0,0,0,0.10); -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.18, 0, 3);">
                    <padding>
                        <Insets top="28.0" right="24.0" bottom="24.0" left="24.0"/>
                    </padding>
                    <StackPane style="-fx-background-color: rgba(138, 0, 17, 0.09); -fx-background-radius: 12; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                        <Label text="☰"
                               style="-fx-font-size: 34px; -fx-text-fill: #8a0011;" />
                    </StackPane>
                    <Label text="View Questions"
                           style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111111;" />
                    <Label text="Browse and solve coding problems from various courses"
                           wrapText="true"
                           style="-fx-font-size: 19px; -fx-text-fill: #6f6f6f;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Button fx:id="exploreQuestionsButton"
                            mnemonicParsing="false"
                            text="Explore Questions"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-min-height: 52; -fx-background-color: #8a0011; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 18px; -fx-font-weight: 600;" />
                </VBox>

                <VBox GridPane.columnIndex="1"
                      spacing="18.0"
                      style="-fx-background-color: white; -fx-border-color: rgba(0,0,0,0.10); -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.18, 0, 3);">
                    <padding>
                        <Insets top="28.0" right="24.0" bottom="24.0" left="24.0"/>
                    </padding>
                    <StackPane style="-fx-background-color: rgba(138, 0, 17, 0.09); -fx-background-radius: 12; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                        <Label text="🏆"
                               style="-fx-font-size: 34px; -fx-text-fill: #8a0011;" />
                    </StackPane>
                    <Label text="Daily Challenge"
                           style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111111;" />
                    <Label text="Take on today's challenge and maintain your streak"
                           wrapText="true"
                           style="-fx-font-size: 19px; -fx-text-fill: #6f6f6f;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Button fx:id="startChallengeButton"
                            mnemonicParsing="false"
                            text="Start Challenge"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-min-height: 52; -fx-background-color: #8a0011; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 18px; -fx-font-weight: 600;" />
                </VBox>

                <VBox GridPane.columnIndex="2"
                      spacing="18.0"
                      style="-fx-background-color: white; -fx-border-color: rgba(0,0,0,0.10); -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.18, 0, 3);">
                    <padding>
                        <Insets top="28.0" right="24.0" bottom="24.0" left="24.0"/>
                    </padding>
                    <StackPane style="-fx-background-color: rgba(138, 0, 17, 0.09); -fx-background-radius: 12; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                        <Label text="＋"
                               style="-fx-font-size: 34px; -fx-text-fill: #8a0011;" />
                    </StackPane>
                    <Label text="Add Question"
                           style="-fx-font-size: 24px; -fx-font-weight: 700; -fx-text-fill: #111111;" />
                    <Label text="Create a new coding problem for students to practice"
                           wrapText="true"
                           style="-fx-font-size: 19px; -fx-text-fill: #6f6f6f;" />
                    <Region VBox.vgrow="ALWAYS" />
                    <Button fx:id="createQuestionButton"
                            mnemonicParsing="false"
                            text="Create Question"
                            maxWidth="1.7976931348623157E308"
                            style="-fx-min-height: 52; -fx-background-color: #f5f5f5; -fx-text-fill: #111111; -fx-border-color: rgba(0,0,0,0.15); -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-insets: 0; -fx-font-size: 18px; -fx-font-weight: 600;" />
                </VBox>
            </GridPane>

            <VBox spacing="18.0">
                <Label text="Your Progress"
                       style="-fx-font-size: 32px; -fx-font-weight: 800; -fx-text-fill: #111111;" />

                <GridPane hgap="24.0" vgap="24.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3333" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3333" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3333" />
                    </columnConstraints>

                    <HBox GridPane.columnIndex="0"
                          alignment="CENTER_LEFT"
                          spacing="18.0"
                          style="-fx-background-color: white; -fx-border-color: rgba(0,0,0,0.10); -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.18, 0, 3); -fx-min-height: 128;">
                        <padding>
                            <Insets top="20.0" right="24.0" bottom="20.0" left="20.0"/>
                        </padding>
                        <StackPane style="-fx-background-color: rgba(26, 191, 94, 0.12); -fx-background-radius: 14; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                            <Label text="◎"
                                   style="-fx-font-size: 34px; -fx-font-weight: 800; -fx-text-fill: #18a84f;" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label text="Problems Solved"
                                   style="-fx-font-size: 19px; -fx-text-fill: #6c6c6c;" />
                            <Label fx:id="problemsSolvedLabel"
                                   text="0"
                                   style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: #111111;" />
                        </VBox>
                    </HBox>

                    <HBox GridPane.columnIndex="1"
                          alignment="CENTER_LEFT"
                          spacing="18.0"
                          style="-fx-background-color: white; -fx-border-color: rgba(0,0,0,0.10); -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.18, 0, 3); -fx-min-height: 128;">
                        <padding>
                            <Insets top="20.0" right="24.0" bottom="20.0" left="20.0"/>
                        </padding>
                        <StackPane style="-fx-background-color: rgba(54, 115, 255, 0.15); -fx-background-radius: 14; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                            <Label text="⌘"
                                   style="-fx-font-size: 34px; -fx-font-weight: 800; -fx-text-fill: #2f69ff;" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label text="Courses Active"
                                   style="-fx-font-size: 19px; -fx-text-fill: #6c6c6c;" />
                            <Label fx:id="coursesActiveLabel"
                                   text="0"
                                   style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: #111111;" />
                        </VBox>
                    </HBox>

                    <HBox GridPane.columnIndex="2"
                          alignment="CENTER_LEFT"
                          spacing="18.0"
                          style="-fx-background-color: white; -fx-border-color: rgba(0,0,0,0.10); -fx-border-width: 1; -fx-border-radius: 18; -fx-background-radius: 18; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0.18, 0, 3); -fx-min-height: 128;">
                        <padding>
                            <Insets top="20.0" right="24.0" bottom="20.0" left="20.0"/>
                        </padding>
                        <StackPane style="-fx-background-color: rgba(158, 52, 255, 0.14); -fx-background-radius: 14; -fx-min-width: 72; -fx-min-height: 72; -fx-max-width: 72; -fx-max-height: 72; -fx-alignment: CENTER;">
                            <Label text="♕"
                                   style="-fx-font-size: 34px; -fx-font-weight: 800; -fx-text-fill: #9e34ff;" />
                        </StackPane>
                        <VBox spacing="2.0">
                            <Label text="Achievements"
                                   style="-fx-font-size: 19px; -fx-text-fill: #6c6c6c;" />
                            <Label fx:id="achievementsLabel"
                                   text="0"
                                   style="-fx-font-size: 36px; -fx-font-weight: 800; -fx-text-fill: #111111;" />
                        </VBox>
                    </HBox>
                </GridPane>
            </VBox>
        </VBox>
    </content>
</ScrollPane>