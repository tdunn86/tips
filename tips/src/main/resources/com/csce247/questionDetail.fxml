<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="768.0" prefWidth="1080.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.csce247.QuestionDetailController"
            style="-fx-background-color: #f2f2f2;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="4"
              style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                     -fx-border-width: 0 0 1 0;"
              prefHeight="56">
            <padding><Insets top="0" right="32" bottom="0" left="32"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="8">
                <Label text="&lt;/&gt;"
                       style="-fx-background-color: #8b1a1a; -fx-text-fill: white;
                              -fx-font-weight: bold; -fx-font-size: 13px;
                              -fx-background-radius: 6; -fx-padding: 6 8 6 8;"/>
                <Label text="TIPS" style="-fx-font-weight: bold; -fx-font-size: 15px;"/>
            </HBox>

            <HBox spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                <padding><Insets left="24"/></padding>
                <Label text="⌂  Home"
                       style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-cursor: hand; -fx-padding: 6 14 6 14;"
                       onMouseClicked="#handleNavHome"/>
                <Label text="≡  Questions"
                       style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-cursor: hand; -fx-padding: 6 14 6 14;"
                       onMouseClicked="#handleNavQuestions"/>
                <Label text="⌛  Daily Challenge"
                       style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-cursor: hand; -fx-padding: 6 14 6 14;"
                       onMouseClicked="#handleNavDailyChallenge"/>
                <Label text="✎  Contributor"
                       style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-cursor: hand; -fx-padding: 6 14 6 14;"
                       onMouseClicked="#handleNavContributor"/>
            </HBox>

            <HBox alignment="CENTER" spacing="10">
                <Label text="JohnGamecock" style="-fx-font-size: 13px;"/>
                <StackPane prefWidth="32" prefHeight="32"
                           style="-fx-background-color: #8b1a1a; -fx-background-radius: 16; -fx-cursor: hand;"
                           onMouseClicked="#handleNavLogout">
                    <Label text="☺" style="-fx-text-fill: white; -fx-font-size: 14;"/>
                </StackPane>
            </HBox>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: #f2f2f2; -fx-background-color: #f2f2f2; -fx-border-color: transparent;"
                    hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">
            <VBox spacing="0">
                <padding><Insets top="24" right="24" bottom="60" left="24"/></padding>

                <Label text="← Back to Questions"
                       style="-fx-font-size: 13px; -fx-text-fill: #555555; -fx-cursor: hand;"
                       onMouseClicked="#handleBackToQuestions">
                    <VBox.margin><Insets bottom="20"/></VBox.margin>
                </Label>

                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- LEFT COLUMN -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <!-- Header card -->
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                     -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                            <Label fx:id="lblTitle" text="Question Title"
                                   style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>

                            <HBox spacing="10" alignment="CENTER_LEFT">
                                <Label fx:id="lblDifficulty" text="Easy"
                                       style="-fx-font-size: 11px; -fx-font-weight: bold;
                                              -fx-background-radius: 999; -fx-padding: 3 10 3 10;"/>
                                <Label fx:id="lblLanguage" text="Java"
                                       style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
                                <Label text="•" style="-fx-text-fill: #bbbbbb;"/>
                                <Label fx:id="lblCourse" text="CSCE 146"
                                       style="-fx-font-size: 12px; -fx-text-fill: #555555;"/>
                            </HBox>

                            <Region prefHeight="1" style="-fx-background-color: #eeeeee;"/>

                            <Label text="Problem Description"
                                   style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111111;"/>
                            <Label fx:id="lblPrompt" text="" wrapText="true"
                                   style="-fx-font-size: 13px; -fx-text-fill: #333333; -fx-line-spacing: 4;"/>
                        </VBox>

                        <!-- Hint card -->
                        <VBox fx:id="hintBox"
                              style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                     -fx-border-width: 1; -fx-background-radius: 10;
                                     -fx-border-radius: 10; -fx-cursor: hand;"
                              onMouseClicked="#handleToggleHint">
                            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
                            <HBox alignment="CENTER_LEFT">
                                <Label text="💡  Hint"
                                       style="-fx-font-size: 14px; -fx-font-weight: bold;"
                                       HBox.hgrow="ALWAYS"/>
                                <Label text="∨" style="-fx-font-size: 14px; -fx-text-fill: #888888;"/>
                            </HBox>
                            <Label fx:id="lblHint" text="" wrapText="true"
                                   visible="false" managed="false"
                                   style="-fx-font-size: 13px; -fx-text-fill: #444444; -fx-padding: 10 0 0 0;"/>
                        </VBox>

                    </VBox>

                    <!-- RIGHT COLUMN -->
                    <VBox spacing="16" prefWidth="300">
                        <VBox spacing="10"
                              style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                     -fx-border-width: 1; -fx-background-radius: 10; -fx-border-radius: 10;">
                            <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                            <StackPane style="-fx-background-color: #8b1a1a; -fx-background-radius: 8; -fx-cursor: hand;"
                                       onMouseClicked="#handleViewSolution">
                                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                                <Label text="👁  View Solution"
                                       style="-fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            </StackPane>

                            <Label fx:id="lblSampleSolution" text="" wrapText="true"
                                   visible="false" managed="false"
                                   style="-fx-font-size: 12px; -fx-text-fill: #333333;
                                          -fx-font-family: monospace;
                                          -fx-background-color: #f6f6f6;
                                          -fx-background-radius: 6; -fx-padding: 10;"/>

                            <Label fx:id="lblSampleExplanation" text="" wrapText="true"
                                   visible="false" managed="false"
                                   style="-fx-font-size: 12px; -fx-text-fill: #555555; -fx-padding: 4 0 0 0;"/>

                            <StackPane style="-fx-background-color: white; -fx-border-color: #e0e0e0;
                                              -fx-border-width: 1; -fx-background-radius: 8; -fx-cursor: hand;">
                                <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
                                <Label text="💬  Discussion"
                                       style="-fx-text-fill: #333333; -fx-font-size: 13px;"/>
                            </StackPane>
                        </VBox>
                    </VBox>

                </HBox>
            </VBox>
        </ScrollPane>
    </center>

</BorderPane>