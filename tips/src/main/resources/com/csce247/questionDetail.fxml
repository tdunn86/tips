<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.csce247.QuestionDetailController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #f6f6f6;">

    <content>
        <VBox spacing="18" style="-fx-background-color: #f6f6f6;">
            <padding><Insets top="24" right="24" bottom="60" left="24"/></padding>

            <Button text="← Back to Questions"
                    onAction="#handleBackToQuestions"
                    style="-fx-background-color: transparent; -fx-cursor: hand;" />

            <!-- HEADER -->
            <VBox spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-background-radius: 10;">
                <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

                <Label fx:id="lblTitle"
                       style="-fx-font-size: 26px; -fx-font-weight: bold;" />

                <VBox spacing="5">
                    <Label fx:id="lblDifficulty"/>
                    <Label fx:id="lblLanguage"/>
                    <Label fx:id="lblCourse"/>
                </VBox>

                <Separator/>

                <Label text="Problem Description"
                       style="-fx-font-size: 15px; -fx-font-weight: bold;" />

                <Label fx:id="lblPrompt" wrapText="true"/>
            </VBox>

            <!-- HINT -->
            <VBox fx:id="hintBox"
                  spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-background-radius: 10;">
                <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>

                <Button fx:id="btnToggleHint" text="Show Hint" onAction="#handleToggleHint"/>
                <Label fx:id="lblHint" visible="false" managed="false" wrapText="true"/>
            </VBox>

            <!-- SOLUTION -->
            <VBox fx:id="solutionBox"
                  spacing="10"
                  style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-background-radius: 10;">
                <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

                <Button text="View Solution"
                        onAction="#handleViewSolution"
                        style="-fx-background-color: #8a0011; -fx-text-fill: white; -fx-cursor: hand;" /> 
                

                <Label fx:id="lblSampleSolution" visible="false" managed="false" wrapText="true"/>
                <Label fx:id="lblSampleExplanation" visible="false" managed="false" wrapText="true"/>
            </VBox>

            <VBox spacing="12"
                  style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-background-radius: 10;">
                <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>

                <Label text="Discussion"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;" />

                <VBox fx:id="repliesContainer" spacing="10"/>

                <TextArea fx:id="replyInput" promptText="Write a reply..." prefRowCount="3"/>

                <Button text="Post Reply"
                        onAction="#handleAddReply"
                        style="-fx-background-color: #8a0011; -fx-text-fill: white; -fx-cursor: hand;" />
            </VBox>

        </VBox>
    </content>
</ScrollPane>