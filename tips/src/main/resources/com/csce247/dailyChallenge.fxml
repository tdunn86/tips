<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #f6f6f6; -fx-background: #f6f6f6;" vbarPolicy="AS_NEEDED" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.csce247.DailyChallengeController">

    <content>
        <AnchorPane style="-fx-background-color: #f6f6f6;">
            <children>
                <VBox layoutX="18.0" layoutY="18.0" prefWidth="1328.0" spacing="18">
                    <children>

                        <VBox spacing="8.0" styleClass="hero-card">
                            <padding>
                                <Insets bottom="28.0" left="28.0" right="28.0" top="28.0" />
                            </padding>
                            <children>
                                <Label fx:id="challengeDateLabel" style="-fx-font-size: 12px; -fx-text-fill: #8b5e0a; -fx-font-weight: bold;" text="" />
                                <Label fx:id="challengeTitleLabel" style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #73000a;" text="" />
                                <Label style="-fx-font-size: 14px; -fx-text-fill: #555555;" text="A new problem appears each day based on your level." />

                                <HBox spacing="10.0">
                                    <children>
                                        <Label fx:id="difficultyLabel" style="-fx-background-color: #e8f5ee; -fx-text-fill: #1a6b3a; -fx-padding: 6 12; -fx-background-radius: 999; -fx-font-size: 12px; -fx-font-weight: bold;" text="" />
                                        <Label fx:id="courseLabel" style="-fx-background-color: #efefef; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 999; -fx-font-size: 12px;" text="" />
                                        <Label fx:id="languageLabel" style="-fx-background-color: #efefef; -fx-text-fill: #333333; -fx-padding: 6 12; -fx-background-radius: 999; -fx-font-size: 12px;" text="" />
                                    </children>
                                </HBox>

                                <Separator />

                                <Label style="-fx-font-size: 13px; -fx-font-weight: bold;" text="Your current progress" />
                                <Label fx:id="statusLabel" style="-fx-font-size: 13px; -fx-text-fill: #616161;" text="" />
                            </children>
                        </VBox>

                        <HBox spacing="16.0">
                            <children>
                                <VBox spacing="12.0" styleClass="card" HBox.hgrow="ALWAYS">
                                    <padding>
                                        <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Problem Prompt" />
                                        <TextArea fx:id="challengePromptArea" editable="false" prefRowCount="12" style="-fx-background-color: white; -fx-font-size: 13px;" wrapText="true" />
                                    </children>
                                </VBox>

                                <VBox prefWidth="320.0" spacing="12.0" styleClass="card">
                                    <padding>
                                        <Insets bottom="22.0" left="22.0" right="22.0" top="22.0" />
                                    </padding>
                                    <children>
                                        <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Leaderboard" />
                                        <Label style="-fx-font-size: 12px; -fx-text-fill: #616161;" text="Top streaks this week" />
                                        <ListView fx:id="leaderboardListView" prefHeight="260.0" />
                                    </children>
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="10.0" styleClass="card">
                            <padding>
                                <Insets bottom="20.0" left="22.0" right="22.0" top="20.0" />
                            </padding>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </content>
</ScrollPane>
